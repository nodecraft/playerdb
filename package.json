{
	"name": "playerdb",
	"version": "1.0.0",
	"private": true,
	"description": "Super scalable Minecraft and Steam player information, powered by Cloudflare Workers",
	"homepage": "https://github.com/nodecraft/playerdb#readme",
	"bugs": {
		"url": "https://github.com/nodecraft/playerdb/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/nodecraft/playerdb.git"
	},
	"license": "MIT",
	"author": "Nodecraft Inc.",
	"type": "module",
	"scripts": {
		"check-types": "tsc --noEmit && tsc --noEmit -p test/tsconfig.json",
		"deploy": "wrangler deploy",
		"deploy:prod": "wrangler deploy --env production",
		"deploy:staging": "wrangler deploy --env staging",
		"dev": "wrangler dev",
		"lint": "npm run lint:js",
		"lint:js": "eslint \"**/*.{js,ts,json}\"",
		"lint:js:fix": "eslint \"**/*.{js,ts,json}\" --fix",
		"test": "npm run test:unit",
		"test:unit": "vitest run",
		"test:unit:dev": "vitest watch"
	},
	"devDependencies": {
		"@cloudflare/containers": "0.3.7",
		"@cloudflare/vitest-pool-workers": "0.18.5",
		"@cloudflare/workers-types": "5.20260715.1",
		"@nodecraft/eslint-config": "49.3.0",
		"@stylistic/eslint-plugin": "5.10.0",
		"@types/node": "24.13.3",
		"cross-env": "10.1.0",
		"dotenv": "17.4.2",
		"eslint": "10.7.0",
		"eslint-plugin-import-newlines": "2.0.0",
		"eslint-plugin-import-x": "4.17.1",
		"eslint-plugin-n": "18.2.2",
		"eslint-plugin-unicorn": "64.0.0",
		"hono": "4.12.30",
		"steamid": "2.1.0",
		"typescript": "6.0.3",
		"typescript-eslint": "8.64.0",
		"vitest": "4.1.10",
		"wrangler": "4.111.0"
	},
	"engines": {
		"node": ">=24",
		"npm": ">=11"
	}
}
